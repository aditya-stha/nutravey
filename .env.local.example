# ─── Shopify Storefront API ───────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your store's values.
# `.env.local` is gitignored — never commit real tokens.

# Full myshopify domain, e.g. nutravey.myshopify.com (no https://)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Public Storefront API access token. Safe to expose to the browser —
# the cart (CartProvider) runs client-side and uses this token.
# Shopify admin → Settings → Apps and sales channels → Develop apps →
# (your app) → API credentials → Storefront API access token.
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_public_storefront_token

# Storefront API version. Matches the @shopify/hydrogen-react build (2026-04).
NEXT_PUBLIC_SHOPIFY_STOREFRONT_API_VERSION=2026-04

# OPTIONAL — private (delegate) Storefront token, server-only. If set, the
# server-side product queries use it for higher rate limits. Never prefix
# this with NEXT_PUBLIC_ — it must not reach the browser.
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=

# ─── Waitlist / pre-launch ─────────────────────────────────────────────────
# Pre-launch mode is ON unless this is exactly "false".
NEXT_PUBLIC_PRE_LAUNCH=true

# OPTIONAL — Admin API access for storing waitlist leads as tagged Shopify
# customers (scope: write_customers). Without it, leads are only logged.
#
# Dev Dashboard apps (created after Jan 2026): paste the app's Client ID +
# Client Secret from the API credentials tab — the site exchanges them for
# short-lived Admin tokens automatically (client_credentials grant).
SHOPIFY_ADMIN_CLIENT_ID=
SHOPIFY_ADMIN_CLIENT_SECRET=
#
# Legacy custom apps (pre-2026) with a static shpat_ token: set it here
# instead and the exchange is skipped.
SHOPIFY_ADMIN_ACCESS_TOKEN=

# OPTIONAL — Cloudflare Turnstile bot protection for the waitlist form.
# Both empty = protection off (honeypot + rate limit still apply).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Analytics ─────────────────────────────────────────────────────────────
# OPTIONAL — GA4 measurement id (G-XXXXXXX). Empty = GA tag not loaded.
NEXT_PUBLIC_GA_ID=

# ─── Ritual Pass & email ───────────────────────────────────────────────────
# REQUIRED IN PRODUCTION — signs the private pass links (any long random
# string, e.g. `openssl rand -hex 32`). Without it, links are forgeable.
PASS_SIGNING_SECRET=

# OPTIONAL — Resend (resend.com) for the reservation confirmation email.
# RESEND_FROM must be a sender on a domain verified in Resend.
RESEND_API_KEY=
RESEND_FROM="Nutravey <pass@yourdomain.com>"

# Launch moment shown on the pass countdown (ISO 8601, UTC).
NEXT_PUBLIC_LAUNCH_DATE=2026-09-01T16:00:00Z

# ─── Shopify webhooks ──────────────────────────────────────────────────────
# Shopify admin → Settings → Notifications → Webhooks. Subscribe
# "Order creation" and "Product update" to https://<your-domain>/api/webhooks/shopify
# and paste the signing secret Shopify displays above the webhook list.
SHOPIFY_WEBHOOK_SECRET=

# OPTIONAL — Customer Account API client id (Headless channel → Customer
# Account API). Enables /account sign-in + order history. The site's
# /account/callback URL must be registered there as a callback URI.
NEXT_PUBLIC_SHOPIFY_CUSTOMER_CLIENT_ID=
